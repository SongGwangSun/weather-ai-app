# ── 필수 환경 변수 ──────────────────────────────────────────────────────────────
# Vercel 대시보드(Settings → Environment Variables)에 아래 두 값을 추가하세요.

# OpenAI API 키 — GPT-4o-mini 옷차림 AI 추천 (필수)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenWeatherMap API 키 — 현재 날씨 (필수)
# 발급: https://home.openweathermap.org/api_keys  (무료 플랜 사용 가능)
OPENWEATHER_API_KEY=your_owm_key_here
